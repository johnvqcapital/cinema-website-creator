<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Build Forge</title>
<style>
*,*::before,*::after{box-sizing:border-box}
:root{--bg:#050607;--ink:#f7f2e8;--muted:rgba(247,242,232,.66);--dim:rgba(247,242,232,.42);--line:rgba(247,242,232,.15);--gold:#f4b84a;--panel:rgba(9,11,12,.74);--blue:#7bb7ff}
html,body{height:100%;margin:0;background:var(--bg);color:var(--ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;overflow:hidden}
button,input,textarea{font:inherit}
button{cursor:pointer}
.app{height:100vh;display:grid;grid-template-columns:1fr;background:radial-gradient(circle at 18% 18%,rgba(123,183,255,.16),transparent 30%),radial-gradient(circle at 88% 78%,rgba(244,184,74,.16),transparent 28%),#050607}
.workflow{display:none}
.brand{display:flex;align-items:center;justify-content:space-between;gap:12px}
.brand h1{margin:0;font-size:18px;letter-spacing:-.04em}.brand span{display:block;margin-top:4px;color:var(--dim);font-size:11px;letter-spacing:.16em;text-transform:uppercase}
.badge{border:1px solid var(--line);border-radius:999px;padding:7px 10px;color:var(--muted);font-size:10px;font-weight:800;letter-spacing:.16em;text-transform:uppercase}
.composer{display:grid;gap:10px}
.composer textarea,.claude-box textarea,.contact-form textarea{width:100%;min-height:104px;resize:vertical;border:1px solid var(--line);border-radius:10px;background:rgba(255,255,255,.045);color:var(--ink);padding:13px;outline:none;line-height:1.45}
.composer textarea:focus{border-color:rgba(244,184,74,.6);box-shadow:0 0 0 3px rgba(244,184,74,.1)}
.actions{display:flex;gap:10px;flex-wrap:wrap}
.primary,.ghost,.icon{border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.07);color:var(--ink);font-weight:800;letter-spacing:.12em;text-transform:uppercase}
.primary{height:42px;flex:1;background:var(--gold);border-color:var(--gold);color:#111;padding:0 16px}.ghost{height:42px;padding:0 16px}.icon{width:40px;height:40px}
.claude-box{display:grid;gap:8px;border:1px solid var(--line);border-radius:12px;padding:10px;background:rgba(255,255,255,.035)}
.claude-head{display:flex;align-items:center;justify-content:space-between;gap:8px}.claude-head b{font-size:11px;letter-spacing:.18em;text-transform:uppercase}.claude-head span{font-size:11px;color:var(--dim)}.claude-box textarea{min-height:84px;font-size:12px}
.key-row{display:grid;grid-template-columns:1fr auto;gap:8px}.key-row input,.contact-form input,.contact-form select{min-width:0;height:40px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.045);color:var(--ink);padding:0 13px;outline:none}.key-row input:focus,.contact-form input:focus,.contact-form select:focus,.contact-form textarea:focus{border-color:rgba(123,183,255,.7);box-shadow:0 0 0 3px rgba(123,183,255,.1)}
.contact-form select option{background:#111;color:#f7f2e8}.contact-form [name="website"]{position:absolute;left:-9999px;opacity:0;pointer-events:none}
.frames{min-height:0;overflow:auto;display:grid;gap:10px;padding-right:2px}
.frame-card{border:1px solid var(--line);border-radius:10px;background:rgba(255,255,255,.045);padding:12px;text-align:left;color:var(--ink);display:grid;gap:7px}
.frame-card.active{border-color:rgba(244,184,74,.8);background:rgba(244,184,74,.1)}
.frame-card b{font-size:13px}.frame-card span{color:var(--muted);font-size:12px;line-height:1.35}.frame-card small{color:var(--gold);font-size:10px;font-weight:900;letter-spacing:.16em;text-transform:uppercase}
.workflow-foot{border:1px solid var(--line);border-radius:10px;padding:12px;background:rgba(255,255,255,.04);color:var(--muted);font-size:12px;line-height:1.45}
.stage{position:relative;min-width:0;overflow:hidden}
.screen{position:absolute;inset:0;opacity:0;pointer-events:none;transition:opacity .42s ease,filter .42s ease;filter:blur(12px)}
.screen.active{opacity:1;pointer-events:auto;filter:blur(0)}
.screen video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;background:#000}
.scrim{position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,0,0,.78),rgba(0,0,0,.18) 46%,rgba(0,0,0,.62)),linear-gradient(180deg,rgba(0,0,0,.22),rgba(0,0,0,.72));pointer-events:none}
.hero{position:absolute;left:clamp(28px,5vw,72px);right:clamp(28px,5vw,72px);bottom:clamp(92px,12vh,132px);z-index:3;max-width:760px}
.eyebrow{font-size:11px;font-weight:900;letter-spacing:.34em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
.hero h2{font-size:clamp(56px,8vw,118px);line-height:.78;letter-spacing:-.075em;margin:0 0 18px;text-transform:uppercase}
.hero p{margin:0;max-width:620px;color:rgba(247,242,232,.78);font-size:17px;line-height:1.45}
.transport{position:absolute;left:50%;bottom:24px;transform:translateX(-50%);z-index:10;display:flex;align-items:center;gap:10px;border:1px solid var(--line);border-radius:999px;background:rgba(0,0,0,.42);backdrop-filter:blur(18px);padding:8px}.count{min-width:64px;text-align:center;font-size:11px;font-weight:900;letter-spacing:.14em;color:var(--muted)}
.page-cue{position:absolute;right:26px;top:50%;transform:translateY(-50%);z-index:12;display:grid;justify-items:center;gap:12px;pointer-events:auto}.page-dots{display:grid;gap:8px}.page-dot{width:8px;height:8px;border:1px solid rgba(247,242,232,.45);border-radius:999px;background:rgba(247,242,232,.16);padding:0;transition:background .2s,border-color .2s,transform .2s}.page-dot.active{background:var(--gold);border-color:var(--gold);transform:scale(1.35)}.swipe-hint{writing-mode:vertical-rl;text-orientation:mixed;color:rgba(247,242,232,.62);font-size:10px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;display:flex;align-items:center;gap:8px}.swipe-hint::after{content:"";width:1px;height:34px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);display:block;animation:hintPulse 1.4s ease-in-out infinite}@keyframes hintPulse{0%,100%{opacity:.28;transform:translateY(-4px)}50%{opacity:1;transform:translateY(4px)}}
.runway-panel,.contact-panel{position:absolute;z-index:30;right:24px;bottom:24px;width:min(520px,calc(100vw - 48px));max-height:min(620px,74vh);display:none;grid-template-rows:auto 1fr;border:1px solid var(--line);border-radius:14px;background:rgba(3,4,5,.88);backdrop-filter:blur(24px);box-shadow:0 28px 90px rgba(0,0,0,.62);overflow:hidden}
.runway-panel.open{display:grid}.panel-head{display:flex;align-items:center;gap:12px;padding:15px 16px;border-bottom:1px solid var(--line)}.panel-head h3{font-size:12px;letter-spacing:.22em;text-transform:uppercase;margin:0}.panel-head button{margin-left:auto}
.contact-panel.open{display:grid}.contact-form{overflow:auto;padding:16px;display:grid;gap:12px}.contact-copy{margin:0;color:var(--muted);font-size:13px;line-height:1.45}.field-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.contact-form label{display:grid;gap:7px;color:var(--dim);font-size:10px;font-weight:900;letter-spacing:.16em;text-transform:uppercase}.contact-form textarea{min-height:116px}.contact-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.contact-note{color:var(--dim);font-size:11px;line-height:1.35}
.prompt-list{overflow:auto;padding:14px;display:grid;gap:12px}.prompt-item{border:1px solid var(--line);border-radius:10px;background:rgba(255,255,255,.04);padding:12px}.prompt-item b{font-size:12px}.prompt-item p{white-space:pre-wrap;color:var(--muted);font-size:12px;line-height:1.45}.prompt-item code{display:block;color:var(--blue);font-size:11px;word-break:break-word}
.readiness-panel{position:absolute;z-index:30;left:24px;bottom:24px;width:min(560px,calc(100vw - 48px));max-height:min(620px,74vh);display:none;grid-template-rows:auto 1fr;border:1px solid var(--line);border-radius:14px;background:rgba(3,4,5,.88);backdrop-filter:blur(24px);box-shadow:0 28px 90px rgba(0,0,0,.62);overflow:hidden}.readiness-panel.open{display:grid}.readiness-body{overflow:auto;padding:14px;display:grid;gap:12px}.readiness-row{border:1px solid var(--line);border-radius:10px;background:rgba(255,255,255,.04);padding:12px;display:grid;gap:8px}.readiness-title{display:flex;align-items:center;justify-content:space-between;gap:10px}.readiness-title b{font-size:12px}.readiness-pill{border:1px solid var(--line);border-radius:999px;padding:5px 8px;font-size:10px;font-weight:900;letter-spacing:.14em;text-transform:uppercase}.readiness-pill.ready{border-color:rgba(87,214,141,.55);color:#57d68d}.readiness-pill.watch{border-color:rgba(244,184,74,.6);color:var(--gold)}.readiness-row p{margin:0;color:var(--muted);font-size:12px;line-height:1.4}.readiness-checks{display:grid;grid-template-columns:1fr 1fr;gap:6px}.readiness-checks span{color:var(--dim);font-size:11px;line-height:1.3}.readiness-checks strong{color:var(--ink);font-weight:800}
.toast{position:absolute;left:50%;top:22px;transform:translateX(-50%);z-index:40;border:1px solid var(--line);border-radius:999px;background:rgba(0,0,0,.52);backdrop-filter:blur(16px);padding:10px 14px;color:var(--ink);font-size:12px;opacity:0;transition:.2s}.toast.show{opacity:1}
@media(max-width:900px){.app{grid-template-columns:1fr}.hero{bottom:110px}.hero h2{font-size:54px}.runway-panel,.contact-panel,.readiness-panel{left:12px;right:12px;bottom:82px;width:auto}.field-grid,.readiness-checks{grid-template-columns:1fr}.page-cue{right:14px}.swipe-hint{font-size:9px}}
</style>
</head>
<body>
<main class="app">
  <aside class="workflow">
    <header class="brand">
      <div><h1>Company X Cinema</h1><span>Any URL to six video themes</span></div>
      <div class="badge">Default videos live</div>
    </header>
    <form class="composer">
      <textarea id="brief" aria-label="Company URL and optional cinema prompt" placeholder="Paste any company URL. Optional: add + cinema direction. Example: buildforge.ai + medieval Four Forges business venture cinema"></textarea>
      <div class="actions"><button class="primary" type="submit">Extract 6 themes</button><button class="ghost" type="button" id="queueAll">Queue Runway</button><button class="ghost" type="button" id="copyClaude">Copy Claude ask</button></div>
    </form>
    <section class="claude-box" aria-label="Claude command intake">
      <div class="claude-head"><b>Claude interface commands</b><span>paste JSON or 6 numbered shots</span></div>
      <textarea id="claudeCommands" placeholder='Paste Claude output here. Best format: [{"title":"Runway Establishing","direction":"Aircraft accelerates...","camera":"wide runway tracking shot","mood":"premium travel"}]'></textarea>
      <div class="key-row"><input id="runwayKey" type="password" autocomplete="off" spellcheck="false" placeholder="Runway API key for automatic queue"><button class="ghost" type="button" id="runWithKey">Run with key</button></div>
      <div class="actions"><button class="ghost" type="button" id="useClaude">Use Claude output</button><button class="ghost" type="button" id="clearClaude">Clear</button></div>
    </section>
    <section class="frames" id="frames" aria-label="Six generated frames"></section>
    <div class="workflow-foot">Paste any company URL. The app infers a brand/category, extracts six cinematic themes, plays default videos immediately, and queues Runway prompts for the final videos.</div>
  </aside>
  <section class="stage" id="stage" aria-label="Cinema preview"></section>
  <nav class="transport" aria-label="Frame navigation"><button class="icon" id="prev" type="button">‹</button><div class="count" id="count">1/6</div><button class="icon" id="next" type="button">›</button><button class="ghost" id="readiness" type="button">Readiness</button><button class="ghost" id="contact" type="button">Contact Us</button></nav>
  <section class="readiness-panel" id="readinessPanel" aria-label="BuildForge readiness">
    <div class="panel-head"><h3>BuildForge readiness</h3><button class="icon" id="closeReadiness" type="button">×</button></div>
    <div class="readiness-body" id="readinessBody"></div>
  </section>
  <section class="runway-panel" id="runwayPanel" aria-label="Runway prompt workflow">
    <div class="panel-head"><h3>Runway workflow</h3><button class="icon" id="closePanel" type="button">×</button></div>
    <div class="prompt-list" id="promptList"></div>
  </section>
  <section class="contact-panel" id="contactPanel" aria-label="Contact Build Forge">
    <div class="panel-head"><h3>Talk To Build Forge</h3><button class="icon" id="closeContact" type="button">×</button></div>
    <form class="contact-form" id="contactForm">
      <p class="contact-copy">Tell us what you want to forge. We will follow up about the right path across Build, Sell, Operate, and Fund.</p>
      <div class="field-grid">
        <label>Name<input id="contactName" name="name" autocomplete="name" required></label>
        <label>Email<input id="contactEmail" name="email" type="email" autocomplete="email" required></label>
      </div>
      <div class="field-grid">
        <label>Company<input id="contactCompany" name="company" autocomplete="organization"></label>
        <label>Stage<select id="contactStage" name="stage"><option>Idea</option><option>Prototype</option><option>Launched</option><option>Scaling</option><option>Need funding</option></select></label>
      </div>
      <label>What are you forging?<textarea id="contactMessage" name="message" required placeholder="A few lines about the venture, what exists today, and where you need leverage."></textarea></label>
      <label aria-hidden="true">Website<input name="website" tabindex="-1" autocomplete="off"></label>
      <div class="contact-actions"><button class="primary" type="submit">Send Inquiry</button><button class="ghost" type="button" id="copyContact">Copy Details</button></div>
      <div class="contact-note" id="contactNote">Submits directly to Build Forge. We will reply by email.</div>
    </form>
  </section>
  <aside class="page-cue" aria-label="Scene pages">
    <div class="swipe-hint">Swipe</div>
    <div class="page-dots" id="pageDots"></div>
  </aside>
  <div class="toast" id="toast"></div>
</main>
<script>
const DEFAULT_VIDEOS=[
  "videos/Seedance%202.0_Seamless%20cinematic%20movie.mp4",
  "videos/Kling%203.0%20Omni_Epic%20high-speed%20racing%20s.mp4",
  "videos/Akool%20Basic_Epic%20winter%20rally%20racing.mp4",
  "videos/Kling%203.0%20Omni_Seamless%20cinematic%20loop%2C.mp4",
  "videos/Kling%203.0%20Omni_Epic%20futuristic%20racing%20m.mp4",
  "videos/Akool%20Basic_Epic%20cinematic%20desert%20ca.mp4"
];
const CONTACT_EMAIL="hello@theforges.ai";
const CONTACT_ENDPOINT=location.protocol==="file:"?"https://motion-vercel.vercel.app/api/contact":"/api/contact";
const BUILT_IN_MANIFESTS={"expedia":{"host":"expedia.com","prompt":"expedia.com + cinematic travel booking film","tasks":[{"frame":1,"title":"Trip Promise","id":"a74c94aa-1653-4a01-969e-4d31fd94a28c","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/214b1977-88dd-48a0-ab0c-692388fa2f5e.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiODlkZTI4YzEyOTI3Mjc5YSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc5MDAxN30.bjWgvOtm2j8nSlU3rt7dKrXd5Plrnf5ZjOZTwcSLU5o"},{"frame":2,"title":"Search To Departure","id":"cb20a54f-3181-4023-858d-eeb6bde2b51f","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/6e940b1b-193c-419d-84ab-e8530f3691fd.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiYzlmNDg1NGU4OTFkYWE1ZSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc0OTMyNn0.jDymTqAiaPM9s3Mn1jGfDg9XSnDs8bbdGSiWLvATIUY"},{"frame":3,"title":"Gate And Boarding","id":"e288ca16-a43a-4787-97a6-158cdb249882","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/f0eac22d-a651-4edb-ad8c-5cf1b609b199.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiNDM2M2NhNDViZjQwMzVmMCIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc0OTMxN30.lg-8s7wHYseF1Wl0gkOk25adoPEDaKHf7ULWEsD-K30"},{"frame":4,"title":"In-Flight Moment","id":"7752bf73-0b4b-4313-9369-0f934bb633aa","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/bad9c803-6fa0-42c2-892e-8d67a859ae9c.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiYTQyODBmY2MyODljZWM3MyIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc2ODkwOH0.5el3MwuWFC1vJfI6Umm_Q4QX8A601j_OTLzKhIsK_-M"},{"frame":5,"title":"Arrival Weather","id":"acb68c93-50f5-4c8f-81d5-e948b1bd45fe","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/454f632e-89b7-41f0-a7de-338c93e69e57.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiYTYxMjg2NTAzMWIzNmI4ZSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc3MTA4OH0.3TZOIscMtYoSiKyBfRwIRFbFpdRm7HFPsXUpRPv9ZSs"},{"frame":6,"title":"Destination Reveal","id":"bdf8bc72-5b65-4ee1-a087-4e408f5d4c0a","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/1acae6bb-c270-4665-b7b1-f9ce53d33a29.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiOWI0NTVkMGMxNDRjY2RiMSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3NzgyMDY4NH0.Wkl-AH4W-FTwRq-DQViJqMi1EZcVKVy8erXIdWH46Xg"}]}};
const BUILT_IN_PENDING_MANIFESTS={"buildforge":{"host":"buildforge.ai","prompt":"buildforge.ai + medieval Four Forges business venture cinema: build, sell, operate, fund, transform","tasks":[{"frame":1,"title":"Build Forge","id":"6cd84234-a71b-4052-9417-653de1ab857a","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/a5243ba8-180c-442e-b2d6-6fa7a76019cb.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiYzkwYWZjMjAzYzZmY2I0YiIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3NzgyMzUyMH0.7q2wiRiZ8XDkAWBKKPMkmRY_lcZVlkCpzBHrPaYouaQ"},{"frame":2,"title":"Sell Forge","id":"4f65db4a-5e9c-48dd-9d30-30869bf1c13c","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/4687a923-3161-4ec1-afb1-addaa1465f0a.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiYTI4NjAwMmU3OGE2ZTEzYSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc1OTY2Mn0.Ui7z98xUCgaYEoTsTdI_zABO5X_I_x4o7XzpR-UP8aY"},{"frame":3,"title":"Operate Forge","id":"0c2042ce-2bae-4d31-9150-b1dfbc8405c7","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/775a87c1-ecf3-4ab7-a490-8309d2240636.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiNjI1MjE3YjMzOWY1NmI3NyIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc2NDc4N30.5Zp3X_RbkwegBxD-uLFp3xf3iapcSnsvrxhbsK6kGgA"},{"frame":4,"title":"Fund Forge","id":"c4d7e8e5-9fd1-4636-8a2b-19451f9ec229","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/0ec6cdb4-dad7-4309-a2a4-a8d6fb4cb583.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiOWEzYzNkNGFlNWRlZWMzZCIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3NzgxMTkxNH0.GFBRI4sm6NSfeAlnsixyWXzLSizHqOaXFBnVqzmoL1M"},{"frame":5,"title":"Transform Forge","id":"812ecbba-7966-44de-8690-f0d44fd3875b","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/39f74526-df9e-45bf-9f32-be5b1efff2b0.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiMGNjYzI2NmIyNTc0ODk3NiIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc2ODE3MX0.1Gqsj986Nq0_A1jrzIKXf9ua7L4M5ZSymx_iCJSfD9I"},{"frame":6,"title":"Forge Your New Venture Here","id":"0f207d9e-da93-4149-8360-930e245880b3","status":"SUCCEEDED","videoUrl":"https://dnznrvs05pmza.cloudfront.net/7451afd6-68c2-49ad-a9aa-e1a4efca2f8d.mp4?_jwt=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJrZXlIYXNoIjoiM2Q0ODg3NGRjNmJlODkzMSIsImJ1Y2tldCI6InJ1bndheS10YXNrLWFydGlmYWN0cyIsInN0YWdlIjoicHJvZCIsImV4cCI6MTc3Nzc2OTgwNX0.Z4SIPvNx87o_NgTl-g2_YhmGj8-sfFb0U-IjdWPOvwU"}]}};
const stage=document.querySelector("#stage"),framesEl=document.querySelector("#frames"),promptList=document.querySelector("#promptList"),pageDots=document.querySelector("#pageDots"),panel=document.querySelector("#runwayPanel"),readinessPanel=document.querySelector("#readinessPanel"),readinessBody=document.querySelector("#readinessBody"),contactPanel=document.querySelector("#contactPanel"),contactForm=document.querySelector("#contactForm"),brief=document.querySelector("#brief"),claudeCommands=document.querySelector("#claudeCommands"),runwayKey=document.querySelector("#runwayKey"),count=document.querySelector("#count"),toast=document.querySelector("#toast");
let frames=[],index=0,touchY=0,touchX=0;
function cleanHost(value){const raw=(value.match(/https?:\/\/[^\s]+|(?:[a-z0-9-]+\.)+[a-z]{2,}/i)||[value.split(/\s+\+/)[0]])[0].trim();try{return new URL(/^https?:\/\//i.test(raw)?raw:`https://${raw}`).hostname.replace(/^www\./,"")}catch{return raw||"company-x.com"}}
function titleCase(text){return text.replace(/\.[a-z]+$/i,"").split(/[-.\s_]+/).filter(Boolean).map(w=>w[0].toUpperCase()+w.slice(1)).join(" ")}
function categoryFor(text){const t=text.toLowerCase(),has=words=>new RegExp(`(^|[^a-z0-9])(${words.join("|")})([^a-z0-9]|$)`,"i").test(t);if(has(["buildforge","build-forge","agentic","orchestration","eval","evaluator","optimizer","scheduler","worktree","acceptance","validator"]))return"build forge";if(has(["forge","forges","theforges","blacksmith","smith","anvil","hammer","ironwork","metalwork","blade","swordsmith","hephaestus","vulcan","wayland","weland","ilmarinen","masamune","tubal","deere"]))return"forge legends";if(has(["travel","flight","airport","hotel","expedia","booking","airline","vacation","trip","resort","tour","kayak","priceline","airbnb"]))return"runway travel";if(has(["car","race","auction","copart","auto","ferrari","vehicle","motors","carsandbids","bringatrailer"]))return"automotive racing";if(has(["phone","device","apple","hardware","retail","watch","laptop","camera","product","shop"]))return"product launch";if(has(["bank","finance","capital","wealth","pay","card","insurance","loan","stripe","paypal","visa","mastercard","chase"]))return"financial trust";if(has(["health","medical","clinic","doctor","care","wellness","fitness","hospital"]))return"healthcare clarity";if(has(["food","restaurant","coffee","kitchen","delivery","grocery","doordash","ubereats","starbucks"]))return"food atmosphere";return"brand cinema"}
function themesFor(category){const map={
  "build forge":["Build Forge","Sell Forge","Operate Forge","Fund Forge","Transform Forge","Forge Your New Venture Here"],
  "forge legends":["Mythic Foundry","Product Forge","GTM Forge","Ops Forge","Capital Forge","Business Artifact"],
  "runway travel":["Trip Promise","Search To Departure","Gate And Boarding","In-Flight Moment","Arrival Weather","Destination Reveal"],
  "automotive racing":["Market Ignition","Hero Vehicle","Inspection Detail","Live Momentum","Victory Moment","Final Call"],
  "product launch":["Product Promise","Material Detail","Feature Choreography","Use Case Moment","Retail Glow","Final Offer"],
  "financial trust":["Trust Establishing","Secure Flow","Human Decision","Data Clarity","Momentum Signal","Confident Close"],
  "healthcare clarity":["Care Promise","Human Calm","Precision Detail","Guided Journey","Outcome Moment","Warm Close"],
  "food atmosphere":["Flavor Establishing","Ingredient Detail","Kitchen Motion","Service Moment","Table Reveal","Final Crave"],
  "brand cinema":["Brand Promise","Core Product","Proof Point","Customer Moment","Texture Study","Final Reveal"]
};return map[category]||map["brand cinema"]}
function promptFor(frame,briefText){return`${frame.company} cinematic website background video, extracted theme ${frame.number} of 6: ${frame.title}.

Creative brief: ${briefText}

Create a ${frame.duration}-second seamless autoplay hero video. Use the default frame as timing reference only; generate a polished final video that fits behind website typography. Focus on real camera motion, clear subject movement, strong depth, premium commercial lighting, and negative space in the lower-left for copy. No readable text, no logos, no UI, no captions, no watermarks.

Extracted theme: ${frame.theme}
Shot direction: ${frame.direction}
Camera: ${frame.camera}
Mood: ${frame.mood}
Output: 1280:720, 24fps, seamless loop.`}
function claudeAsk(briefText){return`You are the command author for Company X Cinema. A user will provide any company URL, sometimes with an optional cinema direction. Infer the brand/category from the URL and create exactly 6 cinematic video commands.

Company URL / brief:

${briefText}

Return only valid JSON, no markdown, no commentary. Shape:
[
  {
    "title": "short cinematic frame title",
    "direction": "what happens in the video, concrete and visual",
    "camera": "camera motion and lens language",
    "mood": "3-6 words",
    "category": "build forge | forge legends | runway travel | automotive racing | product launch | financial trust | healthcare clarity | food atmosphere | brand cinema",
    "theme": "the extracted brand/theme this frame represents"
  }
]

Rules: first extract six distinct company themes from the URL/category, then turn each theme into a real background video command for a website hero. Leave negative space for typography. Avoid text/logos/UI inside the video. Make each command visually distinct.`}
function normalizeClaudeItem(item,i,briefText){const host=cleanHost(briefText),company=titleCase(host),category=item.category||categoryFor(`${host} ${briefText}`),title=item.title||item.theme||`Claude Theme ${i+1}`,frame={id:`c${i+1}`,number:i+1,company,host,category,title,theme:item.theme||title,duration:item.duration||5,videoUrl:item.videoUrl||DEFAULT_VIDEOS[i%DEFAULT_VIDEOS.length],status:"Claude theme loaded",direction:item.direction||item.prompt||item.description||`${title} cinematic background video`,camera:item.camera||"cinematic tracking shot",mood:item.mood||"premium cinematic"};return{...frame,prompt:item.runwayPrompt||item.promptText||promptFor(frame,briefText),claudeCommand:item}}
function parseClaudeCommands(text,briefText){const trimmed=text.trim();if(!trimmed)throw new Error("Paste Claude output first.");let parsed;try{parsed=JSON.parse(trimmed)}catch{const lines=trimmed.split(/\n+/).map(line=>line.replace(/^\s*(?:\d+[\).\:-]?|-)\s*/,"").trim()).filter(Boolean);if(lines.length<6)throw new Error("Claude output needs JSON or at least 6 numbered shot lines.");parsed=lines.slice(0,6).map(line=>{const [title,...rest]=line.split(/\s[-–—:]\s/);return{title:title.slice(0,48),direction:(rest.join(" - ")||line)}})}const list=Array.isArray(parsed)?parsed:parsed.frames||parsed.commands||parsed.shots;if(!Array.isArray(list)||list.length<6)throw new Error("Claude output must contain 6 frames.");return list.slice(0,6).map((item,i)=>normalizeClaudeItem(typeof item==="string"?{direction:item,title:`Claude Frame ${i+1}`}:item,i,briefText))}
function buildFrames(briefText){const host=cleanHost(briefText),company=titleCase(host),category=categoryFor(`${host} ${briefText}`),themes=themesFor(category),copy={
  "build forge":["Turn the raw ore of an idea into a commercial-quality product: prototype, architecture, workflows, proof, and shipping rhythm.","Shape the offer, story, GTM system, sales motion, and campaign assets that turn attention into revenue.","Install the operating system: processes, automation, support loops, delivery infrastructure, dashboards, and accountability.","Forge the funding narrative, milestones, model, data room, investor materials, and capital strategy around the venture.","Use agentic harnesses to turn scattered work into compounding capability across product, GTM, ops, and capital.","Bring us the spark. The Forges help turn the next venture into something built, sold, operated, funded, and ready to scale."]
},directions={
  "build forge":["A massive Sindri/Brokkr-inspired medieval product forge turns a raw glowing ingot into a finished business artifact, with anvils, prototype molds, architecture rings, and molten channels suggesting commercial-quality product creation.","A medieval campaign forge opens into a war-room of banners, signal fires, route maps, offer seals, and launch machinery, turning a polished artifact into demand and sales momentum without readable text.","A hidden dwarven operating forge runs gears, bellows, waterwheels, delivery lanes, support anvils, and automation conduits as one disciplined business engine.","A treasury forge pours molten gold into a venture seal while vault doors, milestone stones, investor relics, and capital ledgers assemble around the artifact without readable text.","Four forged artifacts orbit and fuse around a central anvil: product, GTM, operations, and capital become one compounding venture system with mythic force.","A lone founder carries a spark into the great forge; the doors open to reveal the Four Forges waiting inside, ready to shape the next venture into a business artifact."],
  "forge legends":["Medieval mythic foundry where raw ore becomes a god-level business artifact, with dwarven master-smith energy and Thor's-hammer-level weight without copying any modern superhero design.","A raw glowing ingot is hammered into a polished product artifact, showing what to sell through offer shape, product promise, and prototype energy without readable text.","A forge opens into a medieval campaign war-room, with banners, signal fires, market routes, and a launch seal representing how to sell.","Castle machinery, gears, chains, bellows, waterwheels, and glowing conduits work as one operating system for delivery, automation, SOPs, and support.","Molten gold pours into a treasury seal as vault doors open, representing funding strategy, investor narrative, milestones, and the war chest.","Four forged artifacts converge on a central anvil: product blade, GTM banner, ops gear, and capital coin fuse into one business sigil."],
  "runway travel":["Aircraft accelerates down a glowing runway at dawn, turning the brand promise into motion.","Search transforms into a path from destination cards to airport departure energy.","Jet bridge and aircraft nose reveal through terminal glass, premium boarding atmosphere.","Window-seat wing view climbs through cloud layers and sunrise flare.","Aircraft touches down in rain spray with runway lights stretching into distance.","Camera banks over coastline, hotels, lights, and destination atmosphere."],
  "automotive racing":["A cinematic ignition moment introduces the marketplace as speed and stakes.","Hero vehicle reveal with glossy surfaces, headlights, and immediate desire.","Macro inspection details show wheels, paint, texture, and mechanical proof.","Live momentum with chase-camera energy and fast environmental motion.","Winning moment with smoke, lights, and a premium vehicle exit.","Final call frame with dramatic closing energy and room for CTA copy."],
  "product launch":["Product emerges from darkness as the clearest brand promise.","Macro pass across material, glass, metal, texture, and reflected light.","Features move in choreographed moments around the hero object.","Real-world use case implied through environment and handoff, no identifiable people.","Retail or launch environment glows with display light and architecture.","Final product hold with soft light sweep and premium restraint."],
  "financial trust":["Architectural establishing shot communicates stability and trust.","Secure digital flow shown as glass, light, and controlled movement.","Human decision moment implied through workspace and calm materials.","Data becomes clear through elegant light paths and structured motion.","Momentum signal shows growth without charts or readable numbers.","Confident close with quiet premium light and negative space."],
  "healthcare clarity":["Calm care environment establishes trust and relief.","Soft human-scale motion implied through rooms, hands, and warm light.","Precision detail with clean surfaces, instruments, and controlled movement.","Guided journey through hallway, consultation space, or wellness environment.","Outcome moment with brighter light, movement, and emotional ease.","Warm close with calm atmosphere and clear space for copy."],
  "food atmosphere":["Atmospheric food-world opener with steam, light, and texture.","Ingredient macro with slicing, pouring, seasoning, or freshness.","Kitchen motion with heat, hands implied, and crafted preparation.","Service moment with plate, counter, bag, or table entering frame.","Hero reveal of the final food/drink moment in cinematic light.","Final crave shot with texture, glow, and negative space."],
  "brand cinema":["Atmospheric establishing shot that turns the URL into a film world.","Core product or service appears through category-specific environment.","Proof point shown through material, workflow, speed, trust, or craft.","Customer moment implied through space and motion, no identifiable people.","Macro texture and light study from the brand world.","Clean final reveal with cinematic closure and room for copy."]
};return hydrateSavedVideos(briefText,themes.map((theme,i)=>({id:`f${i+1}`,number:i+1,company,host,category,title:theme,theme,duration:5,videoUrl:DEFAULT_VIDEOS[i%DEFAULT_VIDEOS.length],status:"Default video playing",direction:(directions[category]||directions["brand cinema"])[i],copy:(copy[category]||[])[i]||`${company} turns this theme into a cinematic website moment.`,camera:["wide establishing push","low tracking move","macro dolly","handheld drift","overhead pass","final hero hold"][i],mood:["mythic commercial craft","market momentum","disciplined operating power","capital confidence","transformational force","venture ignition"][i]})).map(frame=>({...frame,prompt:promptFor(frame,briefText)})))}
function eyebrowFor(frame){if(frame.category==="build forge"&&frame.number===6)return"The Four Forges";return frame.category==="build forge"?"The Forges":frame.category}
function render(){stage.replaceChildren();framesEl.replaceChildren();promptList.replaceChildren();pageDots.replaceChildren();frames.forEach((frame,i)=>{const screen=document.createElement("article");screen.className=`screen${i===index?" active":""}`;screen.innerHTML=`<video src="${frame.videoUrl}" autoplay muted loop playsinline></video><div class="scrim"></div><div class="hero"><div class="eyebrow">${eyebrowFor(frame)}</div><h2>${frame.title}</h2><p>${frame.copy||`${frame.company} cinema workflow uses this default library video while Runway creates the final prompted video.`}</p></div>`;const video=screen.querySelector("video");video.addEventListener("error",()=>{if(!DEFAULT_VIDEOS.includes(frame.videoUrl)){frame.status="Generated video unavailable; default restored";frame.videoUrl=DEFAULT_VIDEOS[i%DEFAULT_VIDEOS.length];saveFrameState(frame);render()}});stage.appendChild(screen);
    const card=document.createElement("button");card.type="button";card.className=`frame-card${i===index?" active":""}`;card.innerHTML=`<small>${frame.status}</small><b>${frame.number}. ${frame.title}</b><span>${frame.direction}</span>`;card.addEventListener("click",()=>show(i));framesEl.appendChild(card);
    const dot=document.createElement("button");dot.type="button";dot.className=`page-dot${i===index?" active":""}`;dot.setAttribute("aria-label",`Go to frame ${frame.number}: ${frame.title}`);dot.addEventListener("click",()=>show(i));pageDots.appendChild(dot);
    const prompt=document.createElement("div");prompt.className="prompt-item";prompt.innerHTML=`<b>${frame.number}. ${frame.title}</b><p>${frame.prompt}</p><code>${frame.videoUrl}</code><button class="ghost" type="button">Copy prompt</button>`;prompt.querySelector("button").addEventListener("click",()=>copy(frame.prompt));promptList.appendChild(prompt);
  });count.textContent=`${index+1}/${frames.length}`}
function show(next){index=(next+frames.length)%frames.length;document.querySelectorAll(".screen").forEach((el,i)=>el.classList.toggle("active",i===index));document.querySelectorAll(".frame-card").forEach((el,i)=>el.classList.toggle("active",i===index));document.querySelectorAll(".page-dot").forEach((el,i)=>el.classList.toggle("active",i===index));count.textContent=`${index+1}/${frames.length}`}
function notify(message){toast.textContent=message;toast.classList.add("show");clearTimeout(notify.timer);notify.timer=setTimeout(()=>toast.classList.remove("show"),2600)}
async function copy(text){try{await navigator.clipboard.writeText(text);notify("Prompt copied")}catch{notify("Copy unavailable")}}
function laneName(key){return key.replace(/^\d+_/,"").replace(/_/g," ").replace(/\b\w/g,letter=>letter.toUpperCase())}
function compactCheckValue(value){if(value===true)return"yes";if(value===false)return"no";if(value===null||value===undefined)return"none";return String(value)}
function renderReadiness(data){const lanes=data?.lanes||{};readinessBody.replaceChildren();Object.entries(lanes).forEach(([key,lane])=>{const row=document.createElement("article");row.className="readiness-row";const status=String(lane.status||"unknown");const checks=Object.entries(lane.checks||{}).slice(0,8).map(([name,value])=>`<span>${name.replace(/_/g," ")}: <strong>${compactCheckValue(value)}</strong></span>`).join("");row.innerHTML=`<div class="readiness-title"><b>${laneName(key)}</b><span class="readiness-pill ${status==="ready"?"ready":"watch"}">${status.replace(/_/g," ")}</span></div><p>${lane.goal||""}</p><div class="readiness-checks">${checks}</div>`;readinessBody.appendChild(row)});if(!readinessBody.children.length)readinessBody.innerHTML='<article class="readiness-row"><p>Readiness snapshot unavailable.</p></article>'}
async function loadReadiness(){try{const response=await fetch("buildforge-readiness.json",{cache:"no-store"});if(!response.ok)throw new Error("snapshot unavailable");renderReadiness(await response.json())}catch{renderReadiness(null)}}
function contactPayload(){const data=new FormData(contactForm);return{name:(data.get("name")||"").trim(),email:(data.get("email")||"").trim(),company:(data.get("company")||"").trim(),stage:(data.get("stage")||"").trim(),message:(data.get("message")||"").trim(),website:(data.get("website")||"").trim(),prompt:brief.value.trim(),screen:frames[index]?.title||"Not selected",pageUrl:location.href}}
function contactBody(){const payload=contactPayload();return[`Name: ${payload.name}`,`Email: ${payload.email}`,`Company: ${payload.company||"Not provided"}`,`Stage: ${payload.stage}`,`Prompt: ${payload.prompt}`,`Current screen: ${payload.screen}`,"","What they are forging:",payload.message].join("\n")}
async function submitContact(event){event.preventDefault();const submit=contactForm.querySelector('button[type="submit"]'),note=document.querySelector("#contactNote"),original=submit.textContent;submit.disabled=true;submit.textContent="Sending";note.textContent="Sending your inquiry...";try{const response=await fetch(CONTACT_ENDPOINT,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(contactPayload())});const data=await response.json().catch(()=>({}));if(!response.ok)throw new Error(data.message||data.error||"Could not send inquiry");contactForm.reset();contactPanel.classList.remove("open");note.textContent="Inquiry received. We will reply by email.";notify("Inquiry sent")}catch(error){const body=contactBody(),subject=`Build Forge inquiry: ${document.querySelector("#contactCompany").value.trim()||document.querySelector("#contactName").value.trim()}`;note.textContent="Direct submit failed. Opening an email draft as backup.";location.href=`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;notify("Email draft opened")}finally{submit.disabled=false;submit.textContent=original}}
function getRunwayKey(){return runwayKey.value.trim()||sessionStorage.getItem("runway_api_key")||""}
function requireRunwayKey(){const key=getRunwayKey();if(key){sessionStorage.setItem("runway_api_key",key);return key}notify("Paste a Runway API key to run automatically");runwayKey.focus();return""}
function savedKey(briefText,frame){return`company-x-cinema:${cleanHost(briefText)}:${frame.number}:${frame.title}`}
function isFinal(status){return["SUCCEEDED","FAILED","CANCELED"].includes(String(status||"").toUpperCase())}
function isRunning(frame){return Boolean(frame.polling||frame.queued||frame.taskId&&!isFinal(frame.runwayStatus)&&DEFAULT_VIDEOS.includes(frame.videoUrl))}
function saveFrameState(frame){try{localStorage.setItem(savedKey(brief.value,frame),JSON.stringify({taskId:frame.taskId||"",runwayStatus:frame.runwayStatus||"",status:frame.status,videoUrl:frame.videoUrl||"",updatedAt:Date.now()}))}catch{}}
function hydrateSavedVideos(briefText,nextFrames){return nextFrames.map(frame=>{try{const saved=JSON.parse(localStorage.getItem(savedKey(briefText,frame))||"null");if(saved?.videoUrl&&!DEFAULT_VIDEOS.includes(saved.videoUrl))return{...frame,videoUrl:saved.videoUrl,status:"Runway video ready",taskId:saved.taskId||"",runwayStatus:"SUCCEEDED"};if(saved?.taskId)return{...frame,status:saved.status||"Runway task in progress",taskId:saved.taskId,runwayStatus:saved.runwayStatus||"RUNNING"}}catch{}return frame})}
async function apiRunway(body,timeout=35000){const controller=new AbortController(),timer=setTimeout(()=>controller.abort(),timeout);try{const res=await fetch("/api/runway",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(body),signal:controller.signal});const data=await res.json().catch(()=>({}));if(!res.ok){const error=new Error(data.message||data.error||`HTTP ${res.status}`);error.retryAfter=Number(data.retryAfter)||0;throw error}return data}finally{clearTimeout(timer)}}
function pollDelay(error,attempt){const hinted=error?.retryAfter?error.retryAfter*1000:0;const base=Math.min(45000,5500*Math.pow(1.22,attempt));return Math.max(hinted,base)+Math.random()*2200}
async function pollFrame(frame,apiKey,attempt=0){if(!frame.taskId||frame.polling||frame.runwayStatus==="SUCCEEDED")return;frame.polling=true;try{const data=await apiRunway({action:"retrieve",taskId:frame.taskId,frame:frame.number,company:frame.company,apiKey});frame.runwayStatus=String(data.status||"RUNNING").toUpperCase();if(data.videoUrl){frame.videoUrl=data.videoUrl;frame.status="Runway video ready";frame.polling=false;saveFrameState(frame);render();return}if(isFinal(frame.runwayStatus)){frame.status=`Runway ${frame.runwayStatus.toLowerCase()}`;frame.polling=false;saveFrameState(frame);render();return}frame.status=`Runway ${frame.runwayStatus.toLowerCase()}`;saveFrameState(frame);render();frame.polling=false;setTimeout(()=>pollFrame(frame,apiKey,attempt+1),pollDelay(null,attempt))}catch(error){frame.status=navigator.onLine?`Retrying Runway check: ${error.message}`:"Offline; will resume when online";saveFrameState(frame);render();frame.polling=false;setTimeout(()=>pollFrame(frame,apiKey,attempt+1),pollDelay(error,attempt))}}
function resumePendingFrames(){const key=getRunwayKey();if(!key)return;frames.filter(frame=>frame.taskId&&frame.runwayStatus!=="SUCCEEDED").forEach((frame,i)=>setTimeout(()=>pollFrame(frame,key),i*500))}
async function loadTaskManifest(briefText){const host=cleanHost(briefText),manifestName=host.split(".")[0];let manifest=BUILT_IN_MANIFESTS[manifestName]||BUILT_IN_PENDING_MANIFESTS[manifestName];try{const res=await fetch(`task-manifests/${manifestName}.json`,{cache:"no-store"});if(res.ok)manifest=await res.json()}catch{}if(!manifest||cleanHost(manifest.host||manifest.prompt||"")!==host)return;let changed=false;(manifest.tasks||[]).forEach(task=>{const frame=frames.find(item=>item.number===task.frame||item.title===task.title);if(!frame)return;if(task.videoUrl){frame.videoUrl=task.videoUrl;frame.runwayStatus=task.status||"SUCCEEDED";frame.status="Runway video ready";frame.taskId=task.id||frame.taskId;saveFrameState(frame);changed=true;return}if(task.id&&task.id!==frame.taskId){frame.taskId=task.id;frame.runwayStatus=task.status||"RUNNING";frame.status="Runway task loaded";if(!DEFAULT_VIDEOS.includes(frame.videoUrl))frame.videoUrl=DEFAULT_VIDEOS[(frame.number-1)%DEFAULT_VIDEOS.length];saveFrameState(frame);changed=true}});if(changed){render();notify("Runway videos loaded");resumePendingFrames()}}
async function queueFrame(frame,apiKey=getRunwayKey()){if(frame.videoUrl&&!DEFAULT_VIDEOS.includes(frame.videoUrl)){frame.status="Runway video ready";render();return}if(frame.taskId){frame.status="Resuming existing Runway task";render();pollFrame(frame,apiKey);return}if(frame.queued)return;frame.queued=true;frame.status="Queued to Runway API";render();try{const data=await apiRunway({promptText:frame.prompt,frame:frame.number,company:frame.company,apiKey});frame.taskId=data.id||frame.taskId;frame.runwayStatus=String(data.status||"QUEUED").toUpperCase();frame.status=data.videoUrl?"Runway video ready":`Runway task ${frame.taskId||"created"}`;if(data.videoUrl)frame.videoUrl=data.videoUrl;saveFrameState(frame);render();if(frame.taskId&&!data.videoUrl)pollFrame(frame,apiKey)}catch(error){frame.status=`Default active: ${error.message}`;saveFrameState(frame);render()}finally{frame.queued=false}}
function queueAllFrames(){const key=requireRunwayKey();if(!key)return;const pending=frames.filter(frame=>!isRunning(frame)&&DEFAULT_VIDEOS.includes(frame.videoUrl));if(!pending.length){notify("No pending frames to queue");resumePendingFrames();return}pending.forEach((frame,i)=>setTimeout(()=>queueFrame(frame,key),i*700))}
function create(briefText,sourceFrames){frames=sourceFrames||buildFrames(briefText);index=0;render();loadTaskManifest(briefText);resumePendingFrames();history.replaceState(null,"",`?prompt=${encodeURIComponent(briefText)}`);notify(sourceFrames?"Claude themes applied":"Six themes extracted")}
document.querySelector(".composer").addEventListener("submit",event=>{event.preventDefault();create(brief.value.trim()||"company-x.com + cinematic brand film")});
document.querySelector("#queueAll").addEventListener("click",queueAllFrames);
document.querySelector("#runWithKey").addEventListener("click",queueAllFrames);
runwayKey.addEventListener("input",()=>{const key=getRunwayKey();if(key){sessionStorage.setItem("runway_api_key",key);resumePendingFrames()}});
document.querySelector("#copyClaude").addEventListener("click",()=>copy(claudeAsk(brief.value.trim()||"company-x.com + cinematic brand film")));
document.querySelector("#useClaude").addEventListener("click",()=>{try{create(brief.value.trim()||"company-x.com + cinematic brand film",parseClaudeCommands(claudeCommands.value,brief.value.trim()||"company-x.com + cinematic brand film"))}catch(error){notify(error.message)}});
document.querySelector("#clearClaude").addEventListener("click",()=>{claudeCommands.value="";notify("Claude box cleared")});
document.querySelector("#prev").addEventListener("click",()=>show(index-1));document.querySelector("#next").addEventListener("click",()=>show(index+1));document.querySelector("#prompts")?.addEventListener("click",()=>{contactPanel.classList.remove("open");readinessPanel.classList.remove("open");panel.classList.add("open")});document.querySelector("#closePanel").addEventListener("click",()=>panel.classList.remove("open"));
document.querySelector("#readiness").addEventListener("click",()=>{panel.classList.remove("open");contactPanel.classList.remove("open");readinessPanel.classList.add("open");loadReadiness()});document.querySelector("#closeReadiness").addEventListener("click",()=>readinessPanel.classList.remove("open"));
document.querySelector("#contact").addEventListener("click",()=>{panel.classList.remove("open");readinessPanel.classList.remove("open");contactPanel.classList.add("open");document.querySelector("#contactName").focus()});document.querySelector("#closeContact").addEventListener("click",()=>contactPanel.classList.remove("open"));contactForm.addEventListener("submit",submitContact);document.querySelector("#copyContact").addEventListener("click",()=>copy(contactBody()));
stage.addEventListener("pointerdown",event=>{touchY=event.clientY;touchX=event.clientX});stage.addEventListener("pointerup",event=>{const dy=event.clientY-touchY,dx=event.clientX-touchX;if(Math.abs(dy)>60&&Math.abs(dy)>Math.abs(dx))show(index+(dy<0?1:-1))});
stage.addEventListener("wheel",event=>{if(Math.abs(event.deltaY)>38)show(index+(event.deltaY>0?1:-1))},{passive:true});
document.addEventListener("visibilitychange",()=>{if(!document.hidden)resumePendingFrames()});
window.addEventListener("online",()=>{notify("Back online; checking Runway");resumePendingFrames()});
const params=new URLSearchParams(location.search),initial=params.get("prompt")||params.get("url")||"buildforge.ai + medieval Four Forges business venture cinema: build, sell, operate, fund, transform";
brief.value=initial;create(initial);
loadReadiness();
</script>
</body>
</html>
